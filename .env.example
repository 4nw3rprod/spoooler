# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Gemini (primary script generator, structured-JSON strategy call).
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview,gemini-3-pro-preview,gemini-3.1-flash-lite-preview,gemini-3-flash-preview,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-flash-lite-latest,gemini-flash-latest

# NVIDIA NIM (primary, tried BEFORE Gemini).
# OpenAI-compatible Chat Completions at https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b,deepseek-ai/deepseek-v4-pro,mistralai/mistral-large-3-675b-instruct-2512,moonshotai/kimi-k2.6

# Groq (final fallback when NVIDIA and Gemini are exhausted).
# OpenAI-compatible Chat Completions at https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile,llama-3.1-8b-instant

# Kokoro TTS — `kokoro-say` CLI is the default. Leave KOKORO_API_URL blank to use the CLI.
# Only set KOKORO_API_URL if you run the OpenAI-compatible Kokoro server locally.
KOKORO_API_URL=
KOKORO_API_KEY=
KOKORO_MODEL=kokoro
KOKORO_VOICE=af_bella
KOKORO_SPEED=1.04

# Stock media
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
UNSPLASH_APPLICATION_ID=

# Brand logos (img.logo.dev)
# Public token is embedded in image URLs that the renderer fetches.
# Secret token is server-side only — used for any authenticated logo.dev calls.
LOGO_DEV_PUBLIC_KEY=
LOGO_DEV_TOKEN=

# Optional overrides
# IG_TRANSCRIBER_ROOT: absolute path to an MCP-compatible transcriber (must expose
# run_mcp_server.sh with a transcribe_input tool). Only needed for Instagram
# URL / uploaded-video input — --transcript/--topic flows work without it.
IG_TRANSCRIBER_ROOT=
SCRAPLING_PYTHON=
FFMPEG_PATH=ffmpeg
WHISPER_MODEL=base
REEL_TOOL_PORT=4317
POCKET_TTS_VOICE=
POCKET_TTS_TONE=balanced
POCKET_TTS_QUALITY=4
TADA_PYTHON=
TADA_MODEL=HumeAI/mlx-tada-1b
TADA_WEIGHTS=
TADA_TOKENIZER=
TADA_VOICE_STYLE=excited-explainer
TADA_QUANTIZE=4
TADA_PROMPT_AUDIO=
TADA_PROMPT_TEXT=
TADA_REFERENCE_CACHE=

# Optional AI avatar worker.
# Production should point to a hosted or GPU worker machine.
AVATAR_WORKER_URL=
INFINITETALK_WORKER_URL=
